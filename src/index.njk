---
layout: layouts/base.njk
title: Нүүр
permalink: /
---
<section class="home-heading">
  <h1>{{ site.title }}</h1>
  <p class="tagline">{{ site.description }}</p>
</section>

<div class="home-layout">
  <div class="home-main">
    <section class="featured-posts" aria-labelledby="featured-posts">
      <h2 id="featured-posts">Сүүлийн бичлэгүүдээс</h2>
      {% for post in collections.posts | limit(3) %}
        <article class="featured-post">
          <header>
            <time datetime="{{ post.date | dateIso }}">{{ post.date | dateYmd }}</time>
            <h3><a href="{{ post.url | url }}">{{ post.data.title }}</a></h3>
          </header>
          <div class="excerpt">
            {{ post.templateContent | homeExcerpt | safe }}
          </div>
          <p class="read-more"><a href="{{ post.url | url }}">Цааш унших</a></p>
        </article>
      {% endfor %}
    </section>

    <section aria-labelledby="recent-posts">
      <h2 id="recent-posts">Шинэ бичлэгүүд</h2>
      <ol class="recent-list">
        {% for post in collections.posts | limit(16) %}
          <li>
            <time datetime="{{ post.date | dateIso }}">{{ post.date | dateYmd }}</time>
            <a href="{{ post.url | url }}">{{ post.data.title }}</a>
          </li>
        {% else %}
          <li>Бичлэг хараахан алга.</li>
        {% endfor %}
      </ol>
    </section>
  </div>

  <aside class="home-sidebar" aria-label="Хажуугийн цэс">
    <section>
      <h2>Ангилал</h2>
      <ul class="inline-list">
        {% for category in collections.categoryList | limit(18) %}
          <li><a href="{{ ('/categories/' + category.slug + '/') | url }}">{{ category.name }}</a> <span>({{ category.count }})</span></li>
        {% endfor %}
      </ul>
    </section>

    <section>
      <h2>Түлхүүр үг</h2>
      <ul class="tag-cloud compact">
        {% for tag in collections.popularKeywords | limit(36) %}
          <li><a href="{{ ('/tags/' + (tag.name | tagSlug) + '/') | url }}">{{ tag.name }}</a></li>
        {% endfor %}
      </ul>
    </section>

    <section>
      <h2>Архив</h2>
      <ul class="archive-mini">
        {% for group in collections.postsByMonth | limit(12) %}
          <li><a href="{{ '/archive/' | url }}">{{ group.month }}</a> <span>({{ group.posts.length }})</span></li>
        {% endfor %}
      </ul>
      <p><a href="{{ '/archive/' | url }}">Бүх архив</a></p>
    </section>
  </aside>
</div>
