---
layout: layouts/base.njk
---
<article class="post">
  <header class="post-header">
    <p class="eyebrow">{{ date | readableDate }}</p>
    <h1>{{ title }}</h1>
    {% set pdfUrl = pdf | postPdfUrl(page.url, post_pdfs) %}
    {% if pdfUrl %}
    <p class="post-actions">
      <a class="pdf-download" href="{{ pdfUrl }}">{{ pdf | postPdfLabel }}</a>
    </p>
    {% endif %}
    {% if categories and categories.length %}
    <p class="terms">Ангилал:
      {% for category in categories %}
        <a href="{{ ('/categories/' + (category | tagSlug) + '/') | url }}">{{ category }}</a>{% if not loop.last %}, {% endif %}
      {% endfor %}
    </p>
    {% endif %}
  </header>

  <div class="post-content">
    {{ content | safe }}
  </div>

  {% if tags and tags.length %}
  <footer class="post-meta">
    <p>Түлхүүр үг:
      {% for tag in tags %}
        <a href="{{ ('/tags/' + (tag | tagSlug) + '/') | url }}">{{ tag }}</a>{% if not loop.last %}, {% endif %}
      {% endfor %}
    </p>
  </footer>
  {% endif %}

  <nav class="post-nav" aria-label="Бичлэгийн залуур">
    {% set newerPost = collections.posts | getPreviousCollectionItem(page) %}
    {% set olderPost = collections.posts | getNextCollectionItem(page) %}
    {% if olderPost %}<a href="{{ olderPost.url | url }}">Өмнөх: {{ olderPost.data.title }}</a>{% endif %}
    {% if newerPost %}<a href="{{ newerPost.url | url }}">Дараах: {{ newerPost.data.title }}</a>{% endif %}
  </nav>

  {% include "comments.njk" %}
</article>
